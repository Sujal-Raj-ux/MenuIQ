DATABASE_URL=postgresql://postgres:postgres@localhost:5432/menuiq
GROQ_API_KEY=gsk-your-key-here
# Optional — defaults to llama-3.3-70b-versatile
# GROQ_MODEL=llama-3.3-70b-versatile

# ── Security (production) ──
# Comma-separated frontend origins allowed by CORS. Lock this down in prod.
# CORS_ORIGINS=https://your-frontend.example.com
# If set, every data/chat request must send header: X-API-Key: <this value>.
# Leave unset for local dev (auth is skipped).
# API_KEY=choose-a-long-random-string
# Per-client rate limit for the /chat endpoint.
# CHAT_RATE_LIMIT=20/minute
