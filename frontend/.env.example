# Leave unset in dev to use Vite proxy (see vite.config.js).
# For production, set to your API origin, e.g. http://localhost:8000
# VITE_API_BASE=http://localhost:8000

# Must match the backend API_KEY if the backend enforces auth.
# Sent as the X-API-Key header on every request.
# VITE_API_KEY=choose-a-long-random-string
